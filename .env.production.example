POSTGRES_DB="gazflow_vitrine_db"
POSTGRES_USER="gazflow"
POSTGRES_PASSWORD="replace-with-a-strong-postgres-password"

DATABASE_URL="postgresql://gazflow:replace-with-a-strong-postgres-password@postgres:5432/gazflow_vitrine_db?schema=public"

